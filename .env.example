# GEMINI_API_KEY: Reserved for future agentic features.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this site is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ─── HubSpot Forms API (preferred for production) ────────────────────────────
# When all three of these are set, the contact form, the inline 1-page-summary
# email capture, and the footer "Stay informed" form all POST to HubSpot.
# Find your portal ID in HubSpot under Settings → Account Setup → Account Defaults.
# Form GUIDs come from Marketing → Forms → (your form) → "Embed code".
VITE_HUBSPOT_PORTAL_ID=""
VITE_HUBSPOT_CONTACT_FORM_GUID=""
VITE_HUBSPOT_NEWSLETTER_FORM_GUID=""

# ─── Optional Formspree fallback ─────────────────────────────────────────────
# Used if HubSpot vars are not set. Without this, the contact form falls back
# to opening the user's mail client.
VITE_CONTACT_FORM_ENDPOINT=""
